import { useCrud } from '../useCrud';
import { EstadoMental } from '../../interfaces/historiaClinica/EstadoMental';
import { EstadoMentalApi } from '../../service/estadoMental.service';

export const useEstadoActual = () => {
  const {
    getItem,
    loading,
    error,
    createItem,
    updateItem
  } = useCrud<EstadoMental>(EstadoMentalApi);

  return {
    getItem,
    loading,
    error,
    createItem,
    updateItem
  };
};